# ─── LLM (set at least ONE) ──────────────────────────────────────────────
# Gemini is the default (generous free tier).
GOOGLE_API_KEY=
# Optional alternates — auto-detected if the above is empty.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Override auto-detection if you want a specific provider:
#   auto | gemini | anthropic | openai
LLM_PROVIDER=auto

# Model IDs (defaults are the current best small-fast models)
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# ─── Voice (optional) ────────────────────────────────────────────────────
# If ELEVENLABS_API_KEY is set we use it automatically; otherwise we use
# gTTS (free, no key required).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Images (optional) ───────────────────────────────────────────────────
# Pexels has a generous free tier; without it we fall back to Openverse,
# and then to generated title-card images if offline.
PEXELS_API_KEY=

# ─── Rendering ───────────────────────────────────────────────────────────
FFMPEG_BINARY=ffmpeg
FFMPEG_PRESET=veryfast
FFMPEG_CRF=22

# ─── Server ──────────────────────────────────────────────────────────────
STORAGE_ROOT=./storage
DB_PATH=./storage/brainrotstudy.db
MAX_UPLOAD_MB=100
MAX_CONCURRENT_JOBS=2
CORS_ORIGINS=["http://localhost:3000"]

# ─── Web ─────────────────────────────────────────────────────────────────
# Used by the Next.js dev server to proxy /api/* to the FastAPI server.
NEXT_PUBLIC_API_BASE=/api
